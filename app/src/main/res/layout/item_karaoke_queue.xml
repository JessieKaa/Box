<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/vs_60"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingLeft="@dimen/vs_15"
    android:paddingRight="@dimen/vs_15">

    <LinearLayout
        android:id="@+id/itemMain"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@drawable/shape_source_series_focus"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/vs_10"
        android:paddingRight="@dimen/vs_10">

        <TextView
            android:id="@+id/tvIndex"
            android:layout_width="@dimen/vs_40"
            android:layout_height="wrap_content"
            android:alpha="0.6"
            android:gravity="center"
            android:textColor="@color/color_FFFFFF_90"
            android:textSize="@dimen/ts_20" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/color_FFFFFF_90"
            android:textSize="@dimen/ts_22"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvArtist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/vs_10"
            android:alpha="0.7"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/color_FFFFFF_90"
            android:textSize="@dimen/ts_18" />

        <ImageView
            android:id="@+id/ivPlaying"
            android:layout_width="@dimen/vs_30"
            android:layout_height="@dimen/vs_30"
            android:layout_marginLeft="@dimen/vs_10"
            android:src="@drawable/v_play"
            android:visibility="invisible" />

    </LinearLayout>

    <ImageView
        android:id="@+id/ivFavorite"
        android:layout_width="@dimen/vs_30"
        android:layout_height="@dimen/vs_30"
        android:layout_marginLeft="@dimen/vs_10"
        android:background="@drawable/button_dialog_vod"
        android:clickable="true"
        android:focusable="true"
        android:scaleType="centerInside"
        android:src="@drawable/icon_no_collect" />

    <ImageView
        android:id="@+id/ivDelete"
        android:layout_width="@dimen/vs_35"
        android:layout_height="@dimen/vs_35"
        android:layout_marginLeft="@dimen/vs_10"
        android:background="@drawable/button_dialog_vod"
        android:clickable="true"
        android:focusable="true"
        android:scaleType="centerInside"
        android:src="@drawable/icon_delete" />

</LinearLayout>
