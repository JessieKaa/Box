<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Background carousel for audio-only playback. Drawn BELOW mVideoView (earlier
         document order = lower z). When the player surface is GONE (audio mode), this
         shows through. Toggled by KaraokeActivity.applyAudioOnlyUi. -->
    <com.github.tvbox.osc.karaoke.widget.KaraokeBgCarouselView
        android:id="@+id/bgCarouselView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <com.github.tvbox.osc.player.MyVideoView
        android:id="@+id/mVideoView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Full-screen scrolling lyric for audio-only playback. Sits above mVideoView so it
         shows through when the player surface is GONE, but below llSelectLayer so the
         song browser stays interactive. Driven by KaraokeActivity (visibility + position
         polling). The controller no longer owns this view — its old home inside the
         controller went 0x0 when mVideoView was set to GONE. -->
    <com.github.tvbox.osc.karaoke.lyric.KaraokeFullLyricView
        android:id="@+id/karaokeFullLyricView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/llSelectLayer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF111111"
        android:orientation="vertical">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/vs_70"
            android:background="#CC000000"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="@dimen/vs_15"
            android:paddingRight="@dimen/vs_15">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="@dimen/vs_40"
                android:layout_height="@dimen/vs_40"
                android:focusable="true"
                android:background="@drawable/button_dialog_vod"
                android:src="@drawable/v_back"
                android:nextFocusDown="@id/rvArtists"
                android:nextFocusRight="@id/etSearch" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/vs_15"
                android:text="@string/hm_karaoke"
                android:textColor="@color/color_FFFFFF_90"
                android:textSize="@dimen/ts_26"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="@dimen/vs_45"
                android:layout_marginLeft="@dimen/vs_20"
                android:layout_weight="1"
                android:background="@drawable/input_search"
                android:focusable="true"
                android:hint="@string/karaoke_search_hint"
                android:inputType="text"
                android:maxLines="1"
                android:paddingLeft="@dimen/vs_15"
                android:paddingRight="@dimen/vs_15"
                android:textColor="@color/color_FFFFFF_90"
                android:textColorHint="#70FFFFFF"
                android:textSize="@dimen/ts_20"
                android:nextFocusDown="@id/rvSongGrid"
                android:nextFocusLeft="@id/ivBack"
                android:nextFocusRight="@id/tvChangeFolder" />

            <TextView
                android:id="@+id/tvChangeFolder"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/vs_45"
                android:layout_marginLeft="@dimen/vs_15"
                android:background="@drawable/button_dialog_vod"
                android:focusable="true"
                android:gravity="center"
                android:paddingLeft="@dimen/vs_15"
                android:paddingRight="@dimen/vs_15"
                android:text="@string/karaoke_change_folder"
                android:textColor="@color/color_FFFFFF_90"
                android:textSize="@dimen/ts_20"
                android:nextFocusDown="@id/rvSongGrid"
                android:nextFocusLeft="@id/etSearch"
                android:nextFocusRight="@id/tvTabAll" />

            <LinearLayout
                android:id="@+id/llTabs"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/vs_15"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvTabAll"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/vs_45"
                    android:background="@drawable/shape_karaoke_tab"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingLeft="@dimen/vs_20"
                    android:paddingRight="@dimen/vs_20"
                    android:text="@string/karaoke_all_songs"
                    android:textColor="@color/color_FFFFFF_90"
                    android:textSize="@dimen/ts_22"
                    android:nextFocusDown="@id/rvSongGrid"
                    android:nextFocusLeft="@id/tvChangeFolder"
                    android:nextFocusRight="@id/tvTabQueue" />

                <TextView
                    android:id="@+id/tvTabQueue"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/vs_45"
                    android:layout_marginLeft="@dimen/vs_10"
                    android:background="@drawable/shape_karaoke_tab"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingLeft="@dimen/vs_20"
                    android:paddingRight="@dimen/vs_20"
                    android:textColor="@color/color_FFFFFF_90"
                    android:textSize="@dimen/ts_22"
                    android:nextFocusDown="@id/rvSongGrid"
                    android:nextFocusLeft="@id/tvTabAll"
                    android:nextFocusRight="@id/tvTabFavorites" />

                <TextView
                    android:id="@+id/tvTabFavorites"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/vs_45"
                    android:layout_marginLeft="@dimen/vs_10"
                    android:background="@drawable/shape_karaoke_tab"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingLeft="@dimen/vs_20"
                    android:paddingRight="@dimen/vs_20"
                    android:text="@string/karaoke_tab_favorites"
                    android:textColor="@color/color_FFFFFF_90"
                    android:textSize="@dimen/ts_22"
                    android:nextFocusDown="@id/rvSongGrid"
                    android:nextFocusLeft="@id/tvTabQueue"
                    android:nextFocusRight="@id/tvSettings" />

                <TextView
                    android:id="@+id/tvSettings"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/vs_45"
                    android:layout_marginLeft="@dimen/vs_10"
                    android:background="@drawable/shape_source_flag_focus"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingLeft="@dimen/vs_20"
                    android:paddingRight="@dimen/vs_20"
                    android:text="@string/karaoke_settings"
                    android:textColor="@color/color_FFFFFF_90"
                    android:textSize="@dimen/ts_22"
                    android:nextFocusDown="@id/rvSongGrid"
                    android:nextFocusLeft="@id/tvTabFavorites"
                    android:nextFocusRight="@id/tvTabAll" />

            </LinearLayout>

        </LinearLayout>

        <!-- Middle Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Artist Sidebar -->
            <com.owen.tvrecyclerview.widget.TvRecyclerView
                android:id="@+id/rvArtists"
                android:layout_width="@dimen/vs_200"
                android:layout_height="match_parent"
                android:background="#99000000"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:padding="@dimen/vs_5"
                android:nextFocusUp="@id/ivBack"
                android:nextFocusDown="@id/tvStartPlay"
                android:nextFocusRight="@id/rvSongGrid" />

            <!-- Content Area -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <com.owen.tvrecyclerview.widget.TvRecyclerView
                    android:id="@+id/rvSongGrid"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:padding="@dimen/vs_10"
                    android:nextFocusUp="@id/etSearch"
                    android:nextFocusDown="@id/tvStartPlay"
                    android:nextFocusLeft="@id/rvArtists" />

                <com.owen.tvrecyclerview.widget.TvRecyclerView
                    android:id="@+id/rvQueue"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:padding="@dimen/vs_10"
                    android:visibility="gone"
                    android:nextFocusUp="@id/etSearch"
                    android:nextFocusDown="@id/tvStartPlay"
                    android:nextFocusLeft="@id/rvArtists" />

                <com.owen.tvrecyclerview.widget.TvRecyclerView
                    android:id="@+id/rvFavorites"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:padding="@dimen/vs_10"
                    android:visibility="gone"
                    android:nextFocusUp="@id/etSearch"
                    android:nextFocusDown="@id/tvStartPlay"
                    android:nextFocusLeft="@id/rvArtists" />

                <LinearLayout
                    android:id="@+id/llQRCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_marginRight="@dimen/vs_15"
                    android:layout_marginBottom="@dimen/vs_10"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#CC000000"
                    android:padding="@dimen/vs_8">

                    <ImageView
                        android:id="@+id/ivQRCode"
                        android:layout_width="@dimen/vs_120"
                        android:layout_height="@dimen/vs_120" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="手机扫码遥控"
                        android:textColor="#99FFFFFF"
                        android:textSize="@dimen/ts_16"
                        android:layout_marginTop="@dimen/vs_4" />

                </LinearLayout>

            </FrameLayout>

        </LinearLayout>

        <!-- Bottom Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/vs_60"
            android:background="#CC000000"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="@dimen/vs_20"
            android:paddingRight="@dimen/vs_20">

            <TextView
                android:id="@+id/tvNowPlaying"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/color_FFFFFF_90"
                android:textSize="@dimen/ts_20" />

            <TextView
                android:id="@+id/tvStartPlay"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/vs_45"
                android:background="@drawable/button_dialog_vod"
                android:focusable="true"
                android:gravity="center"
                android:paddingLeft="@dimen/vs_20"
                android:paddingRight="@dimen/vs_20"
                android:textColor="@color/color_FFFFFF_90"
                android:textSize="@dimen/ts_22"
                android:visibility="gone"
                android:nextFocusUp="@id/rvSongGrid"
                android:nextFocusLeft="@id/rvArtists"
                android:nextFocusRight="@id/ivPlayPauseBottom" />

            <ImageView
                android:id="@+id/ivPlayPauseBottom"
                android:layout_width="@dimen/vs_45"
                android:layout_height="@dimen/vs_45"
                android:layout_marginLeft="@dimen/vs_15"
                android:background="@drawable/button_dialog_vod"
                android:focusable="true"
                android:src="@drawable/v_play"
                android:visibility="gone"
                android:nextFocusUp="@id/rvSongGrid"
                android:nextFocusLeft="@id/tvStartPlay"
                android:nextFocusRight="@id/ivNextBottom" />

            <ImageView
                android:id="@+id/ivNextBottom"
                android:layout_width="@dimen/vs_45"
                android:layout_height="@dimen/vs_45"
                android:layout_marginLeft="@dimen/vs_15"
                android:background="@drawable/button_dialog_vod"
                android:focusable="true"
                android:src="@drawable/v_next"
                android:visibility="gone"
                android:nextFocusUp="@id/rvSongGrid"
                android:nextFocusLeft="@id/ivPlayPauseBottom" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
