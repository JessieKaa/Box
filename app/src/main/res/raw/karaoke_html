<!DOCTYPE html>
<html lang="zh-cmn-Hans">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1,user-scalable=0,viewport-fit=cover">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title>卡拉OK遥控</title>
    <link rel="stylesheet" type="text/css" href="style.css">
    <link rel="stylesheet" type="text/css" href="ui.css">
    <style>
        * { -webkit-tap-highlight-color: transparent; }
        body { --weui-BG-0: #111; background: #111 !important; color: #fff; margin: 0; padding: 0;
            padding-top: constant(safe-area-inset-top);
            padding-top: env(safe-area-inset-top);
        }
        .page { height: 100vh; display: flex; flex-direction: column; overflow: hidden;
            padding-bottom: constant(safe-area-inset-bottom);
            padding-bottom: env(safe-area-inset-bottom);
            background-color: #111 !important;
        }

        /* Header */
        .karaoke-header {
            padding: 12px 16px; background: #1a1a1a; border-bottom: 1px solid #2a2a2a;
            flex-shrink: 0; display: flex; align-items: center; justify-content: space-between;
        }
        .karaoke-header h2 { margin: 0; font-size: 17px; font-weight: 600; color: #fff; }
        .karaoke-header a { color: #888; font-size: 14px; text-decoration: none; }

        /* Inactive */
        .inactive-banner { display: none; flex: 1; flex-direction: column;
            align-items: center; justify-content: center; gap: 12px; }
        .inactive-banner.show { display: flex; }
        .inactive-banner .icon { font-size: 48px; opacity: 0.4; }
        .inactive-banner .text { color: #999; font-size: 15px; text-align: center; line-height: 1.6; }
        .inactive-banner .text strong { color: #1aad19; font-weight: 500; }

        /* Now Playing */
        .now-playing {
            padding: 14px 16px 10px; background: linear-gradient(180deg, #1e1e1e 0%, #181818 100%);
            border-bottom: 1px solid #2a2a2a; flex-shrink: 0;
        }
        .now-playing .song-info { display: flex; align-items: baseline; gap: 8px; margin-bottom: 10px; }
        .now-playing .song-title { font-size: 15px; color: #fff; font-weight: 600;
            overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; }
        .now-playing .song-artist { font-size: 13px; color: #888; white-space: nowrap; }

        .now-playing .progress-row { display: flex; align-items: center; gap: 10px; }
        .now-playing .progress-row .time { min-width: 36px; font-size: 12px; color: #777;
            font-variant-numeric: tabular-nums; }
        .now-playing .progress-row .time:last-child { text-align: right; }
        .now-playing .progress-bar { flex: 1; height: 28px; display: flex; align-items: center;
            position: relative; }
        .now-playing .progress-track { width: 100%; height: 4px; background: #333;
            border-radius: 2px; position: relative; }
        .now-playing .progress-fill { height: 100%; background: #1aad19; border-radius: 2px;
            width: 0%; position: relative; }

        .now-playing .controls { display: flex; justify-content: center; align-items: center;
            gap: 24px; margin-top: 8px; }
        .now-playing .controls button {
            border: none; background: transparent; color: #ccc; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            padding: 8px; transition: color 0.15s;
        }
        .now-playing .controls button:active { color: #fff; }
        .now-playing .controls .btn-side { width: 48px; height: 48px; font-size: 22px; }
        .now-playing .controls .btn-main {
            width: 56px; height: 56px; font-size: 28px; border-radius: 50%;
            background: #1aad19; color: #fff;
        }
        .now-playing .controls .btn-main:active { background: #149115; }

        /* Track panel */
        .track-panel { display: none; background: #181818; border-top: 1px solid #2a2a2a;
            flex-shrink: 0; }
        .track-panel.show { display: block; }
        .track-panel .track-header { display: flex; justify-content: space-between;
            align-items: center; padding: 10px 16px 6px; }
        .track-panel .track-header span { font-size: 13px; color: #999; }
        .track-panel .track-header button { background: none; border: none; color: #666;
            font-size: 18px; cursor: pointer; padding: 0 4px; }
        .track-panel .track-list { padding: 0 16px 12px; }
        .track-panel .track-item { display: flex; align-items: center; padding: 10px 12px;
            border-radius: 8px; cursor: pointer; margin-bottom: 4px; }
        .track-panel .track-item:active { background: #222; }
        .track-panel .track-item.selected { background: rgba(26,173,25,0.12); }
        .track-panel .track-item .track-name { flex: 1; font-size: 14px; color: #ccc;
            overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .track-panel .track-item.selected .track-name { color: #1aad19; }
        .track-panel .track-item .track-check { color: #1aad19; font-size: 14px;
            margin-left: 8px; visibility: hidden; }
        .track-panel .track-item.selected .track-check { visibility: visible; }

        /* Tabs */
        .tab-bar { display: flex; background: #1a1a1a; flex-shrink: 0;
            border-bottom: 1px solid #2a2a2a; }
        .tab-bar .tab { flex: 1; text-align: center; padding: 12px 0; color: #777;
            cursor: pointer; font-size: 14px; position: relative; transition: color 0.2s; }
        .tab-bar .tab.active { color: #1aad19; font-weight: 500; }
        .tab-bar .tab.active::after { content: ''; position: absolute; bottom: 0; left: 20%;
            right: 20%; height: 2px; background: #1aad19; border-radius: 1px; }
        .tab-bar .tab .badge { display: inline-block; background: #1aad19; color: #fff;
            font-size: 11px; padding: 1px 6px; border-radius: 8px; margin-left: 4px;
            vertical-align: middle; font-weight: 500; }

        /* Search */
        .search-bar { padding: 10px 16px; background: #141414; flex-shrink: 0; }
        .search-bar .search-wrap { position: relative; display: flex; align-items: center; }
        .search-bar .search-icon { position: absolute; left: 12px; color: #666; font-size: 14px;
            pointer-events: none; }
        .search-bar input {
            width: 100%; padding: 10px 12px 10px 34px; border-radius: 8px;
            border: 1px solid #2a2a2a; background: #1e1e1e; color: #fff; font-size: 16px;
            box-sizing: border-box; outline: none; transition: border-color 0.2s;
        }
        .search-bar input:focus { border-color: #1aad19; }
        .search-bar input::placeholder { color: #555; }

        /* Artist chips */
        .artist-chips { padding: 8px 16px; display: flex; gap: 8px; overflow-x: auto;
            flex-shrink: 0; background: #141414;
            -ms-overflow-style: none; scrollbar-width: none; }
        .artist-chips::-webkit-scrollbar { display: none; }
        .artist-chips .chip {
            white-space: nowrap; padding: 7px 16px; border-radius: 16px;
            background: #252525; color: #aaa; font-size: 13px; cursor: pointer;
            flex-shrink: 0; border: 1px solid transparent; transition: all 0.15s;
        }
        .artist-chips .chip:active { background: #2f2f2f; }
        .artist-chips .chip.active { background: rgba(26,173,25,0.15); color: #1aad19;
            border-color: rgba(26,173,25,0.3); }

        /* Song list */
        .song-list { flex: 1; overflow-y: auto; -webkit-overflow-scrolling: touch; }
        .song-item {
            display: flex; align-items: center; padding: 12px 16px;
            border-bottom: 1px solid #1e1e1e; cursor: pointer;
        }
        .song-item:active { background: #1a1a1a; }
        .song-item .index { width: 28px; font-size: 13px; color: #555; text-align: center;
            flex-shrink: 0; }
        .song-item .info { flex: 1; min-width: 0; }
        .song-item .info .title { font-size: 15px; color: #fff; overflow: hidden;
            text-overflow: ellipsis; white-space: nowrap; }
        .song-item .info .artist { font-size: 12px; color: #999; margin-top: 3px; }
        .song-item .add-btn {
            flex-shrink: 0; padding: 6px 14px; border-radius: 14px;
            background: transparent; color: #1aad19; font-size: 13px;
            border: 1px solid #1aad19; cursor: pointer; transition: all 0.15s;
            min-width: 52px; text-align: center;
        }
        .song-item .add-btn:active { background: rgba(26,173,25,0.15); }
        .song-item .add-btn.queued { color: #555; border-color: #333; pointer-events: none; }

        /* Queue item */
        .queue-item {
            display: flex; align-items: center; padding: 12px 16px;
            border-bottom: 1px solid #1e1e1e; cursor: pointer; position: relative;
        }
        .queue-item:active { background: #1a1a1a; }
        .queue-item.playing { background: rgba(26,173,25,0.06); }
        .queue-item.playing::before { content: ''; position: absolute; left: 0; top: 8px;
            bottom: 8px; width: 3px; background: #1aad19; border-radius: 0 2px 2px 0; }
        .queue-item .index { width: 28px; font-size: 13px; color: #555; text-align: center;
            flex-shrink: 0; }
        .queue-item .info { flex: 1; min-width: 0; }
        .queue-item .info .title { font-size: 15px; color: #fff; overflow: hidden;
            text-overflow: ellipsis; white-space: nowrap; }
        .queue-item .info .artist { font-size: 12px; color: #999; margin-top: 3px; }
        .queue-item.playing .info .title { color: #1aad19; }
        .queue-item.playing .index { color: #1aad19; }
        .queue-item .remove-btn {
            flex-shrink: 0; width: 32px; height: 32px; border-radius: 50%;
            background: transparent; color: #666; font-size: 16px; border: none;
            cursor: pointer; display: flex; align-items: center; justify-content: center;
            transition: all 0.15s;
        }
        .queue-item .remove-btn:active { background: rgba(204,0,0,0.15); color: #c44; }

        /* Panels */
        .content-panel { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
        .panel-library, .panel-queue { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
        .panel-queue { display: none; }

        /* Empty */
        .empty-hint { text-align: center; padding: 60px 20px; color: #555; font-size: 14px; }
        .empty-hint .empty-icon { font-size: 36px; opacity: 0.3; margin-bottom: 12px; }
    </style>
</head>
<body>
<div class="page">
    <div class="karaoke-header">
        <h2>卡拉OK遥控</h2>
        <a href="/">&#8592; 返回</a>
    </div>

    <div id="inactiveBanner" class="inactive-banner show">
        <div class="icon">&#127908;</div>
        <div class="text">请先在 <strong>TV上打开卡拉OK</strong><br>即可开始遥控点歌</div>
    </div>

    <div id="mainContent" style="display:none; flex:1; flex-direction:column; overflow:hidden;">
        <!-- Now Playing -->
        <div class="now-playing" id="nowPlaying" style="display:none;">
            <div class="song-info">
                <span class="song-title" id="npTitle">--</span>
                <span class="song-artist" id="npArtist"></span>
            </div>
            <div class="progress-row">
                <span class="time" id="npTimeCurrent">0:00</span>
                <div class="progress-bar" id="npProgressBar">
                    <div class="progress-track"><div class="progress-fill" id="npProgressFill"></div></div>
                </div>
                <span class="time" id="npTimeTotal">0:00</span>
            </div>
            <div class="controls">
                <button class="btn-side" id="btnPrev" title="上一首">&#9198;</button>
                <button class="btn-main" id="btnPlayPause" title="播放/暂停">&#9654;</button>
                <button class="btn-side" id="btnNext" title="下一首">&#9197;</button>
                <button class="btn-side" id="btnTrack" title="切换音轨" style="font-size:16px;">&#127911;</button>
            </div>
        </div>

        <!-- Track selector -->
        <div class="track-panel" id="trackPanel">
            <div class="track-header">
                <span>音轨</span>
                <button onclick="toggleTrackPanel()">&times;</button>
            </div>
            <div class="track-list" id="trackList"></div>
        </div>

        <!-- Tabs -->
        <div class="tab-bar">
            <div class="tab active" id="tabLibrary" onclick="switchTab('library')">曲库</div>
            <div class="tab" id="tabQueue" onclick="switchTab('queue')">已点 <span class="badge" id="queueCount">0</span></div>
        </div>

        <!-- Library Panel -->
        <div class="panel-library" id="panelLibrary">
            <div class="search-bar">
                <div class="search-wrap">
                    <span class="search-icon">&#128269;</span>
                    <input type="text" id="searchInput" placeholder="搜索歌曲或歌手..." oninput="onSearchInput()">
                </div>
            </div>
            <div class="artist-chips" id="artistChips"></div>
            <div class="song-list" id="songList"></div>
        </div>

        <!-- Queue Panel -->
        <div class="panel-queue" id="panelQueue">
            <div class="song-list" id="queueList"></div>
        </div>
    </div>
</div>
<script src="jquery.js"></script>
<script src="karaoke.js"></script>
</body>
</html>
